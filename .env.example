# Discord bot token (create at https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Discord webhook URL (optional — replies appear as "Cola" instead of bot)
# Create at: Discord channel settings → Integrations → Webhooks → New Webhook
# Copy the full URL (https://discord.com/api/webhooks/...)
DISCORD_WEBHOOK=

# Comma-separated Discord channel IDs to listen on
DISCORD_CHANNEL_IDS=1519719204071280640
